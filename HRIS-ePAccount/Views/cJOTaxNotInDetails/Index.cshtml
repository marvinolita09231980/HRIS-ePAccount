@model HRIS_ePAccount.Models.User_Menu

@{
    ViewBag.Title = "JO Tax - Not In Tax Details";
}

<style>
    .swal-wide {
        width: 60vw !important;
        max-width: 1200px !important;
    }
    .swal-wide .swal-content {
        max-height: 85vh;
        overflow-y: auto;
    }
    @@media (max-width: 1200px) { .swal-wide { width: 85vw !important; } }
    @@media (max-width: 768px)  { .swal-wide { width: 95vw !important; } }

    .gear-loader {
        position: fixed; top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.35);
        z-index: 9999;
        display: flex; align-items: center; justify-content: center;
    }
    .gear-box {
        background: #fff; padding: 25px 40px;
        border-radius: 8px; text-align: center;
        box-shadow: 0 0 15px rgba(0,0,0,0.3);
    }
    .gear-text { margin-top: 10px; font-weight: bold; color: #333; }

    #tbl_notindetails thead tr th {
        padding-top: 12px;
        padding-bottom: 12px;
        vertical-align: middle;
        font-size: 18px;
    }

    #tbl_notindetails tbody tr td {
        padding-top: 10px;
        padding-bottom: 10px;
        vertical-align: middle;
        font-size: 18px;
    }
</style>

<script src="~/Angular/ng-cJOTaxNotInDetails.js"></script>

<section ng-app="ng_HRD_App" ng-controller="cJOTaxNotInDetails_ctrlr">

    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox float-e-margins">

                    <div class="ibox-title" style="background:linear-gradient(90deg,#507CD1,#6a82e8);color:#fff;border-radius:5px 5px 0 0;padding:12px 16px;">
                        <h4 style="margin:0;font-weight:600;"><i class="fa fa-list"></i> JO Tax &mdash; Not In Tax Details</h4>
                    </div>

                    <div class="ibox-content">

                        <!-- Header info row -->
                        <div class="row" style="margin-bottom:10px;">
                            <div class="col-md-3">
                                <label class="font-bold">Payroll Year</label>
                                <input class="form-control" ng-model="txtb_year" disabled style="font-weight:bold;" />
                            </div>
                            <div class="col-md-3">
                                <label class="font-bold">Employee ID</label>
                                <input class="form-control" ng-model="txtb_empl_id" disabled style="font-weight:bold;" />
                            </div>
                            <div class="col-md-6 text-right" style="padding-top:22px;">
                                <button type="button" class="btn btn-success" ng-click="btn_generate_action()" style="margin-right:6px;">
                                    <i class="fa fa-share-square-o"></i> Generate
                                </button>
                                <button type="button" class="btn btn-default" ng-click="BackToJOTaxRate()">
                                    <i class="fa fa-arrow-left"></i> Back to JO Tax Rate
                                </button>
                            </div>
                        </div>

                        <!-- Show entries + search -->
                        <div class="row" style="margin-bottom:8px;">
                            <div class="col-md-3">
                                <label class="font-bold" style="margin-right:6px;">Show</label>
                                <select class="form-control" style="width:80px;display:inline-block;"
                                        ng-model="rowLen" ng-change="setNumOfRow(rowLen)">
                                    <option value="5">5</option>
                                    <option value="10" selected>10</option>
                                    <option value="15">15</option>
                                    <option value="20">20</option>
                                </select>
                                <label class="font-bold" style="margin-left:6px;">entries</label>
                            </div>
                            <div class="col-md-9 text-right">
                                <input type="search" class="form-control" style="display:inline-block;width:260px;"
                                       ng-model="search_box"
                                       ng-keyup="search_in_list(search_box)"
                                       placeholder="Search..." />
                            </div>
                        </div>

                        <!-- DataTable -->
                        <div class="table-responsive" style="overflow-x:auto;">
                            <table id="tbl_notindetails" class="table table-striped table-bordered table-hover" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>VOUCHER NO.</th>
                                        <th>REGISTRY NO.</th>
                                        <th>REGISTRY DESCRIPTION</th>
                                        <th>TEMPLATE</th>
                                        <th>MONTH</th>
                                        <th>YEAR</th>
                                        <th>PERIOD FROM</th>
                                        <th>PERIOD TO</th>
                                        <th>POSTED DATE</th>
                                        <th>GROSS PAY</th>
                                        <th>ACTION</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>

                    </div><!-- /ibox-content -->
                </div><!-- /ibox -->
            </div>
        </div>
    </div>

    <!-- Gear loader -->
    <div id="gearLoader" class="gear-loader" style="display:none;">
        <div class="gear-box">
            <i class="fa fa-cog fa-spin fa-3x" style="color:#507CD1;"></i>
            <div class="gear-text">Loading, please wait&hellip;</div>
        </div>
    </div>

</section>
